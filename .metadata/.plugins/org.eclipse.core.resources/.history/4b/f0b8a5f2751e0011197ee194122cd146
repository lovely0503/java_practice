package com.kh.first; //패키지 선언부 : 현재 클래스의 위치가 어디인가

	/*
	 이 안에서는 전부다 주석
	 주석은 아무런 영향을 끼치지 않는다
	 코드를 작성한후 작성한 코드를 쉽게 이해하기 위함
	 주석을 달아놓으면 유지보수 시간이 줄어들 수 있음
	 
	 주석의 종류(두가지만 나머지한개는 3월 23일에!)
	 
	 1. 한줄 주석(//) : 작성할 내용이 한줄일때 사용
	 // 이후부터 모든내용을 주석으로 간주
	 
	 2.여러 줄 주석 ("/* ~~~~~ *"): 작성할 내용이 여러줄일때 사용
	 ~~~~~~~사이의 모든내용을 주석으로 간주
	  */

	/*
	 패키지(package)
	 
	 소스코드를 작성할때 클래스를 만들어 작업하는데
	 모든 클래스들을 동일한패키지에 생성하여 관리하면 복잡하기때문에
	 클래스들을 용도에맞게 구분해서 패키지에 보관하는 것을 권장!
	 
	 하나의 패키지 안에 여러개의 클래스들이 존재할수있음
	 단 동일한 이름의 클래스는 존재할수있음
	 
	 권장사항
	 
	 패키지는 적어도 세 단계 이상으로 만들어주는 것을 권장함
	 
	 */
public class HelloWorld { //클래스명은 HelloWorld라고 지었음 {Scope / Block}
	//Scope(Block){	}는 총괄호로 열리고 닫히는 부분을 이야기하며 복합문을 구성하는 요소
	//종속된 문장이 여러줄 일때 {'로 시작하고'}로 닫습니다
	
	//main method : 프로그램의 시작점(Entry Point), 프로그램당 1개는 있어야함
	public static void main(String[] args){
		
		//Method : 하나의 기능 단위
		//하나의 클래스안에 여러개의 메서드가 존재할수있음
		//메소드안의 구문을 수행하고 싶다면 반드시 호출을 해야됨
		printMyName();
		System.out.print("Hello World~");//출력을 할때 사용하는 기능 
		//논리적인 한 문장이 끝날때 반드시 세미콜론을 붙임~!!
		
	}
	
	public static void printMyName() { //메소드 선언!!!
		//안녕하세요 제 이름은 강민범 입니다. 반갑습니다~
		System.out.print("안녕하세요. 제이름은 강민범 입니다.반갑습니다~");
		
	}//메소드 영역 끝!!
}
